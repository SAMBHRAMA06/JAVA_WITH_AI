package com.conditional_statements;

import java.util.Scanner;

public class ConditionalStatement1 {
	public static void main(String[] args) {
		String str1 ="green";
		String str2 = "green";
		String str2 = new String("green");
		System.out.println("1: "+(str1==str2));
		System.out.println("2: "+str1.equals(str2));
		System.out.println("3: "+str1.compareTo(str2));
	}

}
