package com.inheritance;

class Person {
	String name;

	public Person(String name) {
		super();
		this.name = name;
	}

	public void display() {
		System.out.println("Name: " + name);


	}
}

class Employee extends Person {
	float salary;

	public Employee(String name, float salary) {
		super(name);
		this.salary = salary;
	}

	public void display() {
		super.display();
		System.out.println("Salary: " + salary);
	}
}
class Sam extends Employee{
	int age;

	public Sam(float salary,int age) {
		super(salary);
		this.age = age;
	}
	
}

public class Inheritance2 {
	 public static void main(String[] args) {
	        Sam s = new Sam("Charlie", 50000f, 25);
	        s.display();
	}

}
