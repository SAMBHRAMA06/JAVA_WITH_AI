package com.encapsulation;

class Student {
	public String name;
	public int age;
	public String usn;
	@Override
	public String toString() {
		return "Student [name=" + name + ", age=" + age + ", usn=" + usn + "]";
	}

}

public class GoodStudent {
	public static void main(String[] args) {
		// object
		Student st1 = new Student();
		st1.name = "";
		st1.age = -19;
		st1.usn = "gfsehehte";
		System.out.println(st1);

	}
}
